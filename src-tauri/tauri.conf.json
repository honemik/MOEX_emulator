{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MOEX Emulator",
  "version": "0.2.0",
  "identifier": "com.bigli.moexemulator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MOEX Emulator",
        "width": 1366,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$RESOURCE/database/images/**",
          "$RESOURCE/images/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../database/moex_clean.sqlite": "database/moex_clean.sqlite",
      "../database/images": "database/images"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
