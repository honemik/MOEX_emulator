{
  "name": "moex-emulator",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "prepare-db": "python scripts/build_clean_db.py",
    "dev": "vite --host 0.0.0.0 --port 1420",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "build:desktop": "npm run prepare-db && tauri build --no-bundle",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "docx": "^9.6.1",
    "katex": "^0.16.44",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
